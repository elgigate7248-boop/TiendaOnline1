# ══════════════════════════════════════════════════════════════════════════════
# Variables de entorno - Sistema de Autenticación MySQL (Aiven) + Redis
# ══════════════════════════════════════════════════════════════════════════════

# Servidor
PORT=4000

# ── MySQL (Aiven) ─────────────────────────────────────────────────────────────
DB_HOST=tu_host_mysql
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=tu_base_de_datos
DB_SSL=true

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USER_TTL=3600            # TTL caché de usuarios en segundos (1 hora)

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=cambiar_por_clave_secreta_muy_segura
JWT_EXPIRES_IN=24h
